# Supabase
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical site URL (production only). Set in Vercel to your live domain, e.g.
# https://calendar-dapp.vercel.app — so signup/password emails never use a deleted preview URL.
# Leave unset for local dev (localhost uses the current origin automatically).
# NEXT_PUBLIC_APP_URL=https://your-production-domain.vercel.app

# Web Push (Phase 2B)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Cron (Phase 2C) - Vercel sends this in Authorization header
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# Admin - required for cron to query across users
# From Supabase: Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
